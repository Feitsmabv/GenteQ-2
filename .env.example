# Database (Supabase PostgreSQL - Session Pooler URL)
DATABASE_URL=postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Payload CMS
PAYLOAD_SECRET=RANDOM_SECRET_HERE
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# Supabase Storage (S3-compatible)
# Generate S3 keys at: Supabase → Storage → Settings → S3 Access Keys
S3_ENDPOINT=https://PROJECT_ID.storage.supabase.co/storage/v1/s3
S3_BUCKET=media
S3_REGION=eu-west-3
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY

# Google Analytics (optioneel — wordt beheerd via CookieYes dashboard)
NEXT_PUBLIC_GA_ID=

# CookieYes (cookie consent banner — AVG-compliant)
# Maak een account op cookieyes.com, kopieer je site ID
NEXT_PUBLIC_COOKIEYES_ID=

# Cloudflare Turnstile (spam-bescherming formulieren)
# Maak keys aan op dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (e-mail notificaties bij formulierinzendingen)
# Maak een account op resend.com, verifieer het klantdomein via DNS
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@projectdomein.be

# Upstash Redis (rate limiting voor formulieren op Vercel serverless)
# Maak gratis database op upstash.com → Redis → Create Database (EU region)
# Zonder deze vars valt rate-limit terug op in-memory; werkt NIET op serverless.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase project ID — gebruikt voor public storage URL generatie
# (vervangt fragile regex-parsing van S3_ENDPOINT)
SUPABASE_PROJECT_ID=
